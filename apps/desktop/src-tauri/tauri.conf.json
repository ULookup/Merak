{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Merak",
  "version": "0.1.0",
  "identifier": "com.ulookup.merak",
  "build": {
    "beforeDevCommand": "node scripts/webui-command.mjs dev",
    "beforeBuildCommand": "node scripts/webui-command.mjs build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../../webui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Merak",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"]
  }
}
