{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Merak",
  "version": "0.1.0",
  "identifier": "com.ulookup.merak",
  "build": {
    "beforeDevCommand": "node scripts/webui-command.mjs dev",
    "beforeBuildCommand": "node scripts/webui-command.mjs build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../../webui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Merak Workbench",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "center": true,
        "decorations": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "ULookup",
    "copyright": "Copyright © 2026 ULookup",
    "category": "Productivity",
    "shortDescription": "Merak narrative agent workbench",
    "longDescription": "Merak is a narrative workbench for worldbuilding, agent sessions, story context, generated files, and run monitoring."
  }
}
